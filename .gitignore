# The 2.6 GB working-base mod is copied from the FS22 source and transformed in place by tools/.
# It is a build artifact / large binary asset tree, not hand-authored source — keep it out of git.
# (Re-create with the base copy step; transforms are re-runnable via tools/.)
src/FS25_WildWest_16x/

# Re-bakeable / stale FS22 binary terrain caches
*.i3d.terrain.*.cache

# Logs & scratch
docs/*.log
*.tmp
__pycache__/
out/
reference_logs/

# ============================================================================
# Publish exclusions (added for the public tool release). Nothing here is
# deleted - it stays in your working tree, just not pushed.
# ============================================================================

# Copyrighted FS22 mod content (source maps/vehicles) - the tool READS your own
# install; it must never redistribute game/mod assets.
FS22_WestEnd_Vehicles/
src/

# Build artifacts / diagnostics (regenerated by the tools; not source)
docs/tree_placements.json
docs/p4_texture_remap.json
reference/

# WW-specific data, not the map-agnostic tool itself
autodrive/

# Legacy tools from the old in-place-transform approach (superseded by the
